    "@workspace/ui": "workspace:*",
    "@xyflow/react": "^12.10.2",
    "ai": "^6.0.184",
    "axios": "^1.13.2",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.16.0",
    "motion": "^12.38.0",
    "nanoid": "^5.1.11",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "^19.2.4",
