# --- Database Configuration ---
# Prisma connection string (e.g., PostgreSQL, MySQL, SQLite)
DATABASE_URL=

# --- Authentication (Better Auth & Google OAuth) ---
# Generate a secure secret for Better Auth sessions
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cloud Storage (Cloudflare R2) ---
# Credentials for S3-compatible cloud storage buckets
AWS_REGION="auto"
AWS_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
